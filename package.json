{
  "name": "@leighton-digital/llm-test-tools",
  "version": "1.0.1",
  "description": "A TypeScript library for testing AI responses using AWS Bedrock",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leighton-digital/llm-test-tools.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/leighton-digital/llm-test-tools/issues"
  },
  "homepage": "https://github.com/leighton-digital/llm-test-tools#readme",
  "scripts": {
    "build": "tsc -p tsconfig.build.json --listEmittedFiles",
    "build:watch": "tsc -w -p tsconfig.build.json",
    "dev:setup": "pnpx lefthook install",
    "docs:ref": "typedoc",
    "docs:post": "node scripts/configure-typedoc.mjs",
    "docs:build": "pnpm --prefix docs-site run build",
    "docs:serve": "pnpm --prefix docs-site run serve",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "format:fix": "biome format --write --fix .",
    "format": "biome format --write .",
    "lint": "biome check --linter-enabled=true --formatter-enabled=false .",
    "lint:fix": "biome check --linter-enabled=true --formatter-enabled=true --write .",
    "clean": "rm -rf dist",
    "check": "npx @biomejs/biome check --write",
    "check:staged": "npx @biomejs/biome check --write --staged",
    "postbuild": "rm tsconfig.build.tsbuildinfo",
    "prepublishOnly": "npm run clean && npm run build",
    "preinstall": "npx only-allow pnpm",
    "prepack": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "release": "LEFTHOOK=0 commit-and-tag-version",
    "release:beta": "LEFTHOOK=0 commit-and-tag-version --prerelease beta",
    "release:stable": "LEFTHOOK=0 commit-and-tag-version --release-as 1.0.0",
    "upgrade:deps": "pnpm update --latest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@jest/globals": "30.2.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.3.5",
    "commit-and-tag-version": "12.6.1",
    "commitizen": "4.3.1",
    "conventional-changelog-conventionalcommits": "9.3.0",
    "cz-conventional-changelog": "3.3.0",
    "jest": "30.3.0",
    "lefthook": "2.1.3",
    "ts-jest": "29.4.6",
    "typedoc": "0.28.17",
    "typedoc-plugin-markdown": "4.10.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "3.1004.0"
  },
  "keywords": [
    "CDK",
    "Jest",
    "test"
  ],
  "author": "leighton digital",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
